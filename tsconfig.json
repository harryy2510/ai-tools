{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2023", "DOM"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noEmit": true,
		"types": ["bun"]
	},
	"include": ["src", "test", "tsdown.config.ts"]
}
