			"types": "./dist/vendors/teams/index.d.ts",
			"default": "./dist/vendors/teams/index.js"
		},
		"./telegram": {
			"types": "./dist/vendors/telegram/index.d.ts",
			"default": "./dist/vendors/telegram/index.js"
		},
		"./textract": {
			"types": "./dist/vendors/textract/index.d.ts",
			"default": "./dist/vendors/textract/index.js"
		},
		"./transmute": {
			"types": "./dist/vendors/transmute/index.d.ts",
			"default": "./dist/vendors/transmute/index.js"
		},
		"./web-fetch": {
			"types": "./dist/modules/web-fetch/index.d.ts",
			"default": "./dist/modules/web-fetch/index.js"
		},
		"./woocommerce": {
			"types": "./dist/vendors/woocommerce/index.d.ts",
			"default": "./dist/vendors/woocommerce/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"codegen": "bun scripts/codegen/main.ts",
		"codegen:check": "bun scripts/codegen/main.ts --check",
		"new-module": "bun scripts/new-module.ts",
		"build": "bun run codegen && tsdown",
		"typecheck": "tsc --noEmit",
		"test": "bun test --parallel --reporter=dots",
		"lint": "oxlint --type-aware src test scripts",
		"lint:fix": "oxlint --type-aware --fix src test scripts",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"check": "bun run --parallel format:check lint && bun run codegen:check && bun run test",
		"hooks:install": "lefthook install",
		"hooks:validate": "lefthook validate",
		"prepare": "lefthook install || true",
		"prepublishOnly": "bun run check && bun run build",
		"release": "semantic-release",
		"release:dry": "semantic-release --dry-run"
	},
	"dependencies": {
		"aws4fetch": "1.0.20",
		"es-toolkit": "1.49.0",
		"fast-xml-parser": "5.10.1",
		"mime": "4",
		"mimetext": "3.0.28",
		"ofetch": "1.5.1",
		"p-map": "7.0.6",
		"p-retry": "8.0.0",
		"postal-mime": "2.7.5",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@mastra/core": "1.51.0",
		"@modelcontextprotocol/sdk": "1.29.0",
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/commit-analyzer": "13.0.1",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/github": "12.0.9",
		"@semantic-release/npm": "13.1.5",
		"@semantic-release/release-notes-generator": "14.1.1",
		"@tanstack/ai": "0.42.0",
		"@types/bun": "1.3.14",
		"ai": "5.0.217",
		"conventional-changelog-conventionalcommits": "10.2.1",
		"lefthook": "2.1.10",
		"oxc-parser": "0.140.0",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-tsgolint": "0.25.0",
		"semantic-release": "25.0.8",
		"tsdown": "0.22.12",
		"typescript": "7.0.2"
	},
	"peerDependencies": {
		"@mastra/core": ">=1.0.0",
		"@modelcontextprotocol/sdk": ">=1.0.0",
		"@tanstack/ai": ">=0.40.0",
		"ai": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@mastra/core": {
			"optional": true
		},
		"@modelcontextprotocol/sdk": {
			"optional": true
		},
		"@tanstack/ai": {
			"optional": true
		},
		"ai": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.3.14",
		"node": ">=24"
	},
	"packageManager": "bun@1.3.14"
}
