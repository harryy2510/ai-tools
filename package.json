		},
		"./r2": {
			"types": "./dist/vendors/r2/index.d.ts",
			"default": "./dist/vendors/r2/index.js"
		},
		"./resend": {
			"types": "./dist/vendors/resend/index.d.ts",
			"default": "./dist/vendors/resend/index.js"
		},
		"./s3": {
			"types": "./dist/vendors/s3/index.d.ts",
			"default": "./dist/vendors/s3/index.js"
		},
		"./slack": {
			"types": "./dist/vendors/slack/index.d.ts",
			"default": "./dist/vendors/slack/index.js"
		},
		"./storage": {
			"types": "./dist/modules/storage/index.d.ts",
			"default": "./dist/modules/storage/index.js"
		},
		"./supabase-storage": {
			"types": "./dist/vendors/supabase-storage/index.d.ts",
			"default": "./dist/vendors/supabase-storage/index.js"
		},
