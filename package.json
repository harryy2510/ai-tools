{
	"name": "@harryy/ai-tools",
	"version": "0.0.1",
	"description": "Reusable AI tools with strict schemas and model-facing contracts. Define once; use from Node, edge, Mastra, or AI SDK",
	"license": "MIT",
	"author": "harryy",
	"repository": {
		"type": "git",
		"url": "https://github.com/harryy/ai-tools"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./core": {
			"types": "./dist/core/index.d.ts",
			"default": "./dist/core/index.js"
		},
		"./http": {
			"types": "./dist/http/index.d.ts",
			"default": "./dist/http/index.js"
		},
		"./weather": {
			"types": "./dist/modules/weather/index.d.ts",
			"default": "./dist/modules/weather/index.js"
		},
		"./mastra": {
			"types": "./dist/mastra/index.d.ts",
			"default": "./dist/mastra/index.js"
		}
	},
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "bun test --parallel --reporter=dots",
		"lint": "oxlint --type-aware src test",
		"lint:fix": "oxlint --type-aware --fix src test",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"check": "bun run --parallel format:check lint && bun run test",
		"hooks:install": "lefthook install",
		"hooks:validate": "lefthook validate",
		"prepare": "lefthook install || true",
		"prepublishOnly": "bun run check && bun run build"
	},
	"dependencies": {
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@mastra/core": "1.51.0",
		"@types/bun": "1.3.14",
		"lefthook": "2.1.10",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-tsgolint": "0.25.0",
		"tsdown": "0.22.12",
		"typescript": "7.0.2"
	},
	"peerDependencies": {
		"@mastra/core": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"@mastra/core": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.3.14",
		"node": ">=24"
	},
	"packageManager": "bun@1.3.14"
}
