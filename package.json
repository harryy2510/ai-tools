{
	"name": "@harryy/ai-tools",
	"version": "1.3.0",
	"description": "Reusable AI tools with strict schemas and model-facing contracts. Define once; project to Node, edge, Mastra, AI SDK, TanStack AI, Cloudflare Workers AI, or MCP.",
	"license": "MIT",
	"author": "harryy",
	"repository": {
		"type": "git",
		"url": "https://github.com/harryy2510/ai-tools"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"CHANGELOG.md"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./core": {
			"types": "./dist/core/index.d.ts",
			"default": "./dist/core/index.js"
		},
		"./http": {
			"types": "./dist/http/index.d.ts",
			"default": "./dist/http/index.js"
		},
		"./mastra": {
			"types": "./dist/mastra/index.d.ts",
			"default": "./dist/mastra/index.js"
		},
		"./ai-sdk": {
			"types": "./dist/ai-sdk/index.d.ts",
			"default": "./dist/ai-sdk/index.js"
		},
		"./tanstack": {
			"types": "./dist/tanstack/index.d.ts",
			"default": "./dist/tanstack/index.js"
		},
		"./cloudflare": {
			"types": "./dist/cloudflare/index.d.ts",
			"default": "./dist/cloudflare/index.js"
		},
		"./mcp": {
			"types": "./dist/mcp/index.d.ts",
			"default": "./dist/mcp/index.js"
		},
		"./amazon-sp-api": {
			"types": "./dist/vendors/amazon-sp-api/index.d.ts",
			"default": "./dist/vendors/amazon-sp-api/index.js"
		},
		"./cloudflare-browser": {
			"types": "./dist/vendors/cloudflare-browser/index.d.ts",
			"default": "./dist/vendors/cloudflare-browser/index.js"
		},
		"./cloudflare-email": {
			"types": "./dist/vendors/cloudflare-email/index.d.ts",
			"default": "./dist/vendors/cloudflare-email/index.js"
		},
		"./content-type": {
			"types": "./dist/modules/content-type/index.d.ts",
			"default": "./dist/modules/content-type/index.js"
		},
		"./document-extract": {
			"types": "./dist/modules/document-extract/index.d.ts",
			"default": "./dist/modules/document-extract/index.js"
		},
		"./document-render": {
			"types": "./dist/modules/document-render/index.d.ts",
			"default": "./dist/modules/document-render/index.js"
		},
		"./email": {
			"types": "./dist/modules/email/index.d.ts",
			"default": "./dist/modules/email/index.js"
		},
		"./email-message": {
			"types": "./dist/modules/email-message/index.d.ts",
			"default": "./dist/modules/email-message/index.js"
		},
		"./file-convert": {
			"types": "./dist/modules/file-convert/index.d.ts",
			"default": "./dist/modules/file-convert/index.js"
		},
		"./files": {
			"types": "./dist/modules/files/index.d.ts",
			"default": "./dist/modules/files/index.js"
		},
		"./gotenberg": {
			"types": "./dist/vendors/gotenberg/index.d.ts",
			"default": "./dist/vendors/gotenberg/index.js"
		},
		"./imessage": {
			"types": "./dist/vendors/imessage/index.d.ts",
			"default": "./dist/vendors/imessage/index.js"
		},
		"./katana": {
			"types": "./dist/vendors/katana/index.d.ts",
			"default": "./dist/vendors/katana/index.js"
		},
		"./messaging": {
			"types": "./dist/modules/messaging/index.d.ts",
